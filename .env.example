# ── Vision / OCR step ──
VISION_API_KEY=sk-your-siliconflow-key-here
VISION_BASE_URL=https://api.siliconflow.cn/v1
VISION_OCR_MODEL=PaddlePaddle/PaddleOCR-VL-1.5

# ── Translate / MT step ──
# Set TRANSLATE_API_KEY to use a paid model instead of the free default.
# Compatible with any OpenAI-compatible API (DeepSeek, SiliconFlow, etc.).
# TRANSLATE_API_KEY=sk-your-translate-key-here
# TRANSLATE_BASE_URL=https://api.deepseek.com
# TRANSLATE_MODEL=deepseek-v4-flash

# Fallback when TRANSLATE_API_KEY is empty (free on SiliconFlow)
# TRANSLATE_MT_FREE_MODEL=tencent/Hunyuan-MT-7B

# ── Server ──
LISTEN_HOST=0.0.0.0
LISTEN_PORT=4404
HOST_BIND=0.0.0.0
HOST_PORT=4404
REQUEST_TIMEOUT=45

# ── Game config ──
# GAME_CONFIG_DIR=~/.hermes/retroarch/games

# ── Translation cache (LRU, max entries, default 128) ──
# TRANSLATION_CACHE_SIZE=128
