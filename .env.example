DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
TRANSLATION_MODEL=deepseek-v4-flash
HOST_BIND=0.0.0.0
HOST_PORT=4404

# Optional. Leave empty to use the host-native Docker platform.
# Apple Silicon should generally leave this empty to avoid QEMU OCR crashes.
DOCKER_PLATFORM=
