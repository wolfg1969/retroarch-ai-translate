# ── Vision API (SiliconFlow) ──
# VISION_PROVIDER options:
#   "" (default) = FREE pipeline: PaddleOCR-VL → Hunyuan-MT
#   "siliconflow" = Paid: Qwen3-VL single-call vision translation
VISION_PROVIDER=
VISION_API_KEY=sk-your-siliconflow-key-here
VISION_BASE_URL=https://api.siliconflow.cn/v1

# Model for VISION_PROVIDER=siliconflow (paid)
VISION_MODEL=Qwen/Qwen3-VL-8B-Instruct

# Models for VISION_PROVIDER="" (free, both free on SiliconFlow)
# VISION_OCR_MODEL=PaddlePaddle/PaddleOCR-VL-1.5
# VISION_MT_MODEL=tencent/Hunyuan-MT-7B

# ── Server ──
LISTEN_HOST=0.0.0.0
LISTEN_PORT=4404
HOST_BIND=0.0.0.0
HOST_PORT=4404
REQUEST_TIMEOUT=45

# ── Game config ──
# GAME_CONFIG_DIR=~/.hermes/retroarch/games

# ── Translation cache (LRU, max entries, default 128) ──
# TRANSLATION_CACHE_SIZE=128

# ── Docker ──
# Leave empty to use host-native platform (recommended for Apple Silicon).
DOCKER_PLATFORM=
