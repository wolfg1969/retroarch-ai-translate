# ── DeepSeek API (text translation, used when VISION_PROVIDER is empty) ──
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
TRANSLATION_MODEL=deepseek-v4-flash

# ── Vision API (SiliconFlow, OCR + translation bypasses local OCR) ──
# VISION_PROVIDER options:
#   ""                  = local OCR (PaddleOCR + Tesseract) → DeepSeek translation
#   "siliconflow"       = Qwen3-VL single-call vision translation (paid)
#   "siliconflow-free"  = PaddleOCR-VL → Hunyuan-MT two-step pipeline (FREE)
VISION_PROVIDER=
VISION_API_KEY=sk-your-vision-key-here
VISION_BASE_URL=https://api.siliconflow.cn/v1

# Models for "siliconflow" (paid)
VISION_MODEL=Qwen/Qwen3-VL-8B-Instruct

# Models for "siliconflow-free" (both free on SiliconFlow)
# VISION_OCR_MODEL=PaddlePaddle/PaddleOCR-VL-1.5
# VISION_MT_MODEL=tencent/Hunyuan-MT-7B

# ── Server ──
LISTEN_HOST=0.0.0.0
LISTEN_PORT=4404
HOST_BIND=0.0.0.0
HOST_PORT=4404
REQUEST_TIMEOUT=45

# ── Game config ──
# GAME_CONFIG_DIR=~/.hermes/retroarch/games

# ── OCR debug (save OCR input images + results to debug/ocr/) ──
# OCR_DEBUG_DIR=/debug/ocr

# ── Translation cache (LRU, max entries, default 128) ──
# TRANSLATION_CACHE_SIZE=128

# ── Docker ──
# Leave empty to use host-native platform (recommended for Apple Silicon).
DOCKER_PLATFORM=
